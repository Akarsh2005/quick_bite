# =============================================================================
#  Quick Bite — .gitignore
#  Covers: Node.js (backend, frontend, admin), Python (chatbot), editors, OS
# =============================================================================

# -----------------------------------------------------------------------------
# Dependencies
# -----------------------------------------------------------------------------
node_modules/
.pnp
.pnp.js

# -----------------------------------------------------------------------------
# Environment Variables  *** NEVER commit .env files ***
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example

# -----------------------------------------------------------------------------
# Build Output
# -----------------------------------------------------------------------------
dist/
dist-ssr/
build/
out/

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# -----------------------------------------------------------------------------
# Runtime / OS Files
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# -----------------------------------------------------------------------------
# Editor & IDE
# -----------------------------------------------------------------------------
.vscode/
!.vscode/extensions.json
.idea/
*.iml
.fleet/

# -----------------------------------------------------------------------------
# Python (chatbot training)
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
*.egg-info/
.eggs/
.venv/
venv/
env/
*.egg
pip-log.txt
pip-delete-this-directory.txt

# Model / dataset artifacts (large binary files)
*.pkl
*.pt
*.pth
*.bin
*.safetensors
*.onnx

# Jupyter
.ipynb_checkpoints/
*.ipynb

# -----------------------------------------------------------------------------
# Backend — Express / Node
# -----------------------------------------------------------------------------
# Uploaded files (multer)
backend/uploads/

# Chatbot ML model weights (large binary — store in Git LFS or separately)
backend/models/chatbot_model/*.safetensors
backend/models/chatbot_model/*.bin
backend/models/chatbot_model/*.pt

# -----------------------------------------------------------------------------
# Frontend / Admin — Vite / React
# -----------------------------------------------------------------------------
*.local

# -----------------------------------------------------------------------------
# Testing
# -----------------------------------------------------------------------------
coverage/
.nyc_output/

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
*.tgz
*.zip
.cache/
.parcel-cache/
.turbo/
