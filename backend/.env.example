# Quick Bite Backend — Environment Variables
# Copy this file to .env and fill in your values.

# -----------------------------------------------
# Server
# -----------------------------------------------
PORT=5001
NODE_ENV=development

# -----------------------------------------------
# MongoDB
# -----------------------------------------------
# Atlas connection string:
#   mongodb+srv://<user>:<password>@cluster.mongodb.net/<dbname>
# Local connection string:
#   mongodb://localhost:27017/quickbite
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/quickbite?appName=Cluster0

# -----------------------------------------------
# JWT
# -----------------------------------------------
# Use a long, random secret in production
JWT_SECRET=your_super_secret_key
# Token expiry (e.g. 1h, 7d, 30d)
JWT_EXPIRE=1h

# -----------------------------------------------
# Stripe (Payments)
# -----------------------------------------------
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------
# Frontend URL (used in Stripe redirect)
# -----------------------------------------------
FRONTEND_URL=http://localhost:5173
